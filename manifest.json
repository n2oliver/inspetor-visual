{
  "manifest_version": 3,
  "name": "Inspetor Visual",
  "version": "0.2.3",
  "description": "Visualize e copie os elementos do navegador com um clique.",
  "permissions": [
    "contextMenus",
    "storage",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "insp.html",
    "default_icon": "insp.png"
  },
  "icons": {
    "16": "images/insp-16.png",
    "32": "images/insp-32.png",
    "48": "images/insp-48.png",
    "128": "images/insp-128.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "<all_urls>"
      ],
     "run_at": "document_idle"
    },
    {
      "js": ["scripts/bootstrap-5.0.2-dist/js/bootstrap.min.js"],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}